# CBT Habit Breaker AI - Frontend Configuration
# This is a static webapp deployable to GitHub Pages
# Using Google Generative AI (Gemini)

# Google Generative AI Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
VITE_GOOGLE_API_KEY=your_google_api_key_here
VITE_GEMINI_MODEL=gemini-1.5-flash

# Storage Configuration
VITE_USE_LOCAL_STORAGE=true
VITE_STORAGE_PREFIX=cbt_habit_breaker_

# UI Configuration
VITE_APP_TITLE=CBT Habit Breaker
VITE_MAX_MESSAGE_LENGTH=5000
