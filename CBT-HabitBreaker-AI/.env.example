# CBT Habit Breaker AI - Frontend Configuration
# This is a static webapp deployable to GitHub Pages

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here
VITE_OPENAI_MODEL=gpt-4

# Note: For GitHub Pages deployment, store your API key securely
# Use environment variables during build or a secure proxy service

# Storage Configuration
VITE_USE_LOCAL_STORAGE=true
VITE_STORAGE_PREFIX=cbt_habit_breaker_

# UI Configuration
VITE_APP_TITLE=CBT Habit Breaker
VITE_MAX_MESSAGE_LENGTH=5000
